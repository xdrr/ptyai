{
  "name": "ptyai",
  "version": "0.1.1",
  "author": {
    "name": "Ben Nott",
    "email": "0xdrfff@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xdrr/ptyai.git"
  },
  "homepage": "https://github.com/xdrr/ptyai#readme",
  "bugs": {
    "url": "https://github.com/xdrr/ptyai/issues"
  },
  "description": "MCP server that gives AI agents a persistent PTY with full VT100/ANSI emulation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ptyai": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "install-mcp": "node dist/index.js install",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "pty",
    "terminal",
    "claude",
    "claude-code",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "scripts/postinstall.js",
    "README.md"
  ]
}
